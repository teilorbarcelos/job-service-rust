ENVIRONMENT=local

# SERVER CONFIG
PORT=8888
HOST=0.0.0.0
DEBUG=true

# DATABASE CONFIG
DATABASE_URL=postgresql://postgres:postgrespw@localhost:5432/backend_rust?schema=public
DATABASE_URL_AUDIT=postgresql://postgres:postgrespw@localhost:5432/backend_rust?schema=audit

# CACHE CONFIG
REDIS_URL=redis://127.0.0.1:6379

# AUTHENTICATION
JWT_SECRET=super-secret-key-change-me
JWT_EXPIRES_IN=86400

# EMAIL CONFIG
EMAIL_PROVIDER=mock
EMAIL_SENDER=no-reply@mage-boilerplate.com

# MESSAGING CONFIG (RabbitMQ)
MESSAGING_ENABLED=false
RABBIT_URL=amqp://guest:guest@localhost:5672

